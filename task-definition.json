{
    "family": "secret",
    "containerDefinitions": [
        {
            "name": "secret",
            "image": "618246140803.dkr.ecr.ap-south-1.amazonaws.com/secret:latest",
            "cpu": 300,
            "memory": 300,
            "portMappings": [
                {
                    "containerPort": 80,
                    "hostPort": 0,
                    "protocol": "tcp"
                }
            ],
            "essential": true,
            "environment": [],
            "mountPoints": [],
            "volumesFrom": [],
            "secrets": [
                {
                    "name": "MY_SECRET",
                    "valueFrom": "arn:aws:secretsmanager:us-east-1:618246140803:secret:secret:MY_SECRET::"
                }
            ],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/secret-env-test",
                    "awslogs-region": "us-east-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "taskRoleArn": "arn:aws:iam::618246140803:role/ecsTaskRole",
    "executionRoleArn": "arn:aws:iam::618246140803:role/ecsTaskExecutionRole",
    "networkMode": "bridge",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "EC2"
    ]
}
